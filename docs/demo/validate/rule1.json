{
  "type": "object",
  "properties": {
    "phone": {
      "type": "string",
      "title": "手机号",
      "required": true,
      "rules": {
        "pattern": "^1[3-9]\\d{9}$",
        "message": "请输入正确的手机号"
      }
    },
    "age": {
      "type": "number",
      "title": "年龄",
      "rules": {
        "min": 0,
        "max": 150
      }
    },
    "name": {
      "type": "string",
      "title": "姓名",
      "required": true
    }
  }
}
