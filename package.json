{
  "name": "v3sf",
  "version": "2.0.0-alpha.0",
  "private": true,
  "description": "UI-agnostic JSON Schema form engine for Vue 3",
  "repository": "https://github.com/Muluk-m/schema-form",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r run build",
    "build:core": "pnpm -C packages/core build",
    "build:vant": "pnpm -C packages/vant build",
    "build:element-plus": "pnpm -C packages/element-plus build",
    "dev:vue3": "pnpm -C packages/vue3-example dev",
    "dev:gen": "pnpm -C packages/generator-example dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\"",
    "clean": "rimraf packages/*/dist",
    "commit": "git-cz",
    "prepare": "husky"
  },
  "keywords": [
    "json-schema-form",
    "schema-form",
    "json-schema",
    "vue",
    "vue3",
    "form-generator"
  ],
  "author": {
    "name": "Muluk",
    "email": "maqiqiqan0316@163.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@vue/test-utils": "^2.4.0",
    "@vitejs/plugin-vue-jsx": "^4.0.0",
    "commitizen": "^4.3.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "happy-dom": "^15.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^6.0.0",
    "tsdown": "^0.12.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vant": "^4.9.0",
    "vitest": "^3.0.0",
    "vue": "^3.5.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ],
    "*.{ts,tsx,json,md}": [
      "prettier --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
