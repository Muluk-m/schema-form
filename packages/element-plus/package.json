{
  "name": "@v3sf/element-plus",
  "version": "2.0.0-alpha.0",
  "description": "Element Plus adapter for @v3sf/core",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "dependencies": {
    "@v3sf/core": "workspace:*"
  },
  "peerDependencies": {
    "element-plus": "^2.5.0",
    "vue": "^3.4.0"
  },
  "license": "MIT"
}
