{
  "name": "safe-template-expr",
  "version": "1.0.0",
  "description": "Safe template expression engine with {{ }} syntax. AST-based evaluation, zero eval(), zero dependencies.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "keywords": [
    "expression",
    "template",
    "safe",
    "eval",
    "ast",
    "parser",
    "sandbox",
    "no-eval"
  ],
  "license": "MIT"
}
